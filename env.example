# ══════════════════════════════════════════
# Roblox FFlag Bot — Variables de Entorno
# Copia este archivo como ".env" y rellena
# ══════════════════════════════════════════

# ── OBLIGATORIO ────────────────────────────
# Token de tu bot de Discord
# Consíguelo en: https://discord.com/developers/applications
DISCORD_TOKEN=pon_tu_token_de_discord_aqui

# Clave de API de Anthropic (para el comando /preguntar)
# Consíguela en: https://console.anthropic.com/
ANTHROPIC_API_KEY=pon_tu_clave_de_anthropic_aqui

# ── OPCIONAL (muy recomendado) ─────────────
# Token de GitHub — sube el rate limit de 60 a 5000 peticiones/hora
# Sin este token el bot puede fallar al cargar flags si se reinicia muchas veces
# Consíguelo en: https://github.com/settings/tokens (no necesita ningún permiso especial)
GITHUB_TOKEN=
